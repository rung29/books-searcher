{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "regions": [
        "hnd1"
      ]
    }
  },
  "env": {
    "INTEGRATE_PAGE_SLEEP_SECONDS": "0",
    "INTEGRATE_BOOK_SLEEP_SECONDS": "0",
    "LIB_REQUEST_TIMEOUT": "25"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
